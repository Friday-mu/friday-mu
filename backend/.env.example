# Server Configuration
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# Database Configuration
DATABASE_URL=postgres://user:password@localhost:5432/friday_admin

# GMS Integration
# GMS_BASE_URL = host the FAD backend proxies user-scoped requests to.
# GMS currently lives at admin.friday.mu (both UI + API on same nginx).
# gms.friday.mu is reserved but not in use as of 2026-05.
# GMS_AUTH_TOKEN = optional service-to-service token used only by legacy
# polling routes; user auth flows do NOT use this (they forward the
# end-user JWT instead).
GMS_BASE_URL=https://admin.friday.mu
GMS_AUTH_TOKEN=your_gms_service_token_here

# Slack: bot token for slack_import.js (read), webhook URL for feedback notifySlack (write)
SLACK_BOT_TOKEN=
SLACK_GMS_WEBHOOK_URL=

# Guesty Open-API — service credentials for direct integrations
# Same client_id / client_secret as GMS uses (~/repos/friday-gms/.env).
# Used for reviews, listings, and any future Guesty-direct surface that
# doesn't route through GMS.
GUESTY_CLIENT_ID=your_guesty_client_id_here
GUESTY_CLIENT_SECRET=your_guesty_client_secret_here
GUESTY_BASE_URL=https://open-api.guesty.com/v1
GUESTY_TOKEN_URL=https://open-api.guesty.com/oauth2/token

# Guesty webhook secrets (Svix for the modern POST /api/integrations/guesty/webhook,
# legacy HMAC for the scraper-side endpoints)
GUESTY_SVIX_SECRET=
GUESTY_WEBHOOK_SECRET=

# Kimi (Moonshot) — for FAD-side AI work, e.g. review tag generation
KIMI_API_KEY=your_kimi_api_key_here

# Anthropic (Claude Opus) — used in parallel with Kimi during the
# evaluation phase (translation, tag extraction, etc). Results from both
# models are compared and the better/combined output is used. Long-term
# target is Kimi-only; this slot can be removed when the dual-model phase
# wraps. Get a key from https://console.anthropic.com.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Nanobanana — internal name for Google's Gemini/Imagen image generation
# surface, used by the Design module for moodboard + design-pack image
# generation. Get an API key from https://aistudio.google.com/app/apikey.
# If unset, backend/src/ai/imagegen.js returns a placeholder stub so the
# frontend integration path stays exercised end-to-end without 500s.
NANOBANANA_API_KEY=your_nanobanana_api_key_here
# Model override — defaults to imagen-3.0-generate-002, the GA Imagen 3
# SKU on generativelanguage.googleapis.com as of 2026-05. Rotate via env
# when Google releases a newer model.
NANOBANANA_MODEL=imagen-3.0-generate-002
NANOBANANA_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Breezeway Open-API — write-side integration (create-task on issue conversion)
# Operations module — not yet wired
# Credentials NOT self-serve: request via developer.breezeway.io/docs/obtaining-credentials
# or email support@breezeway.io. Reva used this same path.
BREEZEWAY_CLIENT_ID=your_breezeway_client_id_here
BREEZEWAY_CLIENT_SECRET=your_breezeway_client_secret_here
BREEZEWAY_BASE_URL=https://api.breezeway.io

# Google Routes API — Ops scheduling travel-time estimates.
# Used by POST /api/operations/travel-time/estimate. Prefer a server-only
# key restricted to Routes API; never expose this as NEXT_PUBLIC_*.
GOOGLE_ROUTES_API_KEY=
GOOGLE_ROUTES_URL=https://routes.googleapis.com/directions/v2:computeRoutes

# Security
JWT_SECRET=your_jwt_secret_here

# Local upload directories (FAD-side photo + generic uploads)
FAD_UPLOAD_DIR=
FAD_UPLOAD_PUBLIC_PREFIX=
FAD_GENERIC_UPLOAD_DIR=
FAD_GENERIC_UPLOAD_PUBLIC_PREFIX=
TEAM_UPLOAD_DIR=
TEAM_ATTACHMENT_MAX_BYTES=

# VAPID for Web Push (frontend already wired; backend half-built — see F3 work in flight)
VAPID_PRIVATE_KEY=

# friday.mu website inbox — shared HMAC secret with the public site.
# friday.mu (separate repo) emits webhooks to
# POST /api/inbox/website/friday-website signed with
# HMAC-SHA256(secret, `${timestamp}.${rawBody}`). Both sides must
# agree on the same secret; rotate by setting on both sides
# simultaneously and never logging the value.
# Generate one with: openssl rand -hex 32
FRIDAY_WEBSITE_INBOX_SECRET=your_website_webhook_secret_here

# Resend — guest-facing confirmation email after ops marks a website
# booking paid in the FAD inbox. If unset, the mark-paid flow still
# flips Guesty status to confirmed but skips the guest email (logged
# at warn level). Get a key from https://resend.com — verify the
# friday.mu sending domain first.
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=Friday Retreats <hello@friday.mu>
