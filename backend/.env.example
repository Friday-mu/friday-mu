# Server Configuration
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# Database Configuration
DATABASE_URL=postgres://user:password@localhost:5432/friday_admin

# GMS Integration
# GMS_BASE_URL = host the FAD backend proxies user-scoped requests to.
# GMS_AUTH_TOKEN = optional service-to-service token used only by legacy
# polling routes; user auth flows do NOT use this (they forward the
# end-user JWT instead).
GMS_BASE_URL=https://gms.friday.mu
GMS_AUTH_TOKEN=your_gms_service_token_here

# Slack Integration (Optional)
SLACK_WEBHOOK_URL=your_slack_webhook_url_here
SLACK_CHANNEL=#guest-messages

# OpenAI Integration (for backup AI replies)
OPENAI_API_KEY=your_openai_api_key_here

# Guesty Open-API — service credentials for direct integrations
# Same client_id / client_secret as GMS uses (~/repos/friday-gms/.env).
# Used for reviews, listings, and any future Guesty-direct surface that
# doesn't route through GMS.
GUESTY_CLIENT_ID=your_guesty_client_id_here
GUESTY_CLIENT_SECRET=your_guesty_client_secret_here
GUESTY_BASE_URL=https://open-api.guesty.com
GUESTY_TOKEN_URL=https://open-api.guesty.com/oauth2/token

# Kimi (Moonshot) — for FAD-side AI work, e.g. review tag generation
KIMI_API_KEY=your_kimi_api_key_here

# Breezeway Open-API — write-side integration (create-task on issue conversion)
# Credentials NOT self-serve: request via developer.breezeway.io/docs/obtaining-credentials
# or email support@breezeway.io. Reva used this same path.
BREEZEWAY_CLIENT_ID=your_breezeway_client_id_here
BREEZEWAY_CLIENT_SECRET=your_breezeway_client_secret_here
BREEZEWAY_BASE_URL=https://api.breezeway.io

# Security
JWT_SECRET=your_jwt_secret_here
API_KEY=your_api_key_here