# Auto-generated by next build / next dev — path differs between modes
# (`.next/dev/types/routes.d.ts` vs `.next/types/routes.d.ts`), causing
# spurious diffs each time you swap between `npm run dev` and `npm run build`.
# Safe to gitignore — Next regenerates on demand.
tsconfig.tsbuildinfo

# Local env (per-developer secrets — never commit)
.env.local
.env.*.local
